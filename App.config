<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <appSettings>
        <!-- WebSocket 中转服务器地址 -->
        <add key="WebSocketUrl" value="ws://192.168.23.83:3000" />
        <!-- 文件服务器地址 -->
        <add key="FileServerUrl" value="http://192.168.23.83:3001" />
        <!-- 本地媒体缓存目录 -->
        <add key="MediaPath" value="C:\media" />
        <!-- Office PPT 服务地址（备用，PPT 控制已改用 Interop） -->
        <add key="PPTApiUrl" value="http://127.0.0.1:20165/api" />
    </appSettings>
</configuration>
